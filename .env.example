# ── 서버 환경변수 (server가 읽음) ──
PORT=8787
# 개발 시 Vite dev 서버 주소 (CORS 허용). 프로덕션은 동일 출처라 비워도 됨.
CLIENT_ORIGIN=http://localhost:5173

# ── Supabase ──
SUPABASE_URL=https://supabase-axedu.kodekorea.kr
# ⚠️ service_role 키 (비밀!). Supabase 대시보드 > Project Settings > API > service_role 에서 복사.
# 이 키만 RLS를 우회해 axedu_* 테이블에 접근할 수 있습니다. 절대 클라이언트에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=여기에_service_role_키_붙여넣기

# ── MiniMax (텍스트/대화, 비교 랩) ──
# https://www.minimax.io  (또는 https://api.minimaxi.chat)
MINIMAX_API_KEY=여기에_minimax_키
MINIMAX_GROUP_ID=
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=MiniMax-Text-01

# ── Stability (이미지 생성) ──
# https://platform.stability.ai
STABILITY_API_KEY=여기에_stability_키
STABILITY_BASE_URL=https://api.stability.ai

# ── 안전/쿼터 기본값 (강의실 생성 시 덮어쓸 수 있음) ──
QUOTA_CHAT_PER_ACTIVITY=8
QUOTA_IMAGE_PER_ACTIVITY=4
CLASSROOM_BUDGET_USD=15
